# Copie para .env e preencha os valores reais

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Chrome do operador (obrigatório para Playwright)
# Windows: C:\Users\SeuUsuario\AppData\Local\Google\Chrome\User Data
CHROME_PROFILE_PATH=C:\Users\Pc\AppData\Local\Google\Chrome\User Data
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Ambiente ativo: anthropic | ollama
# Se não definido, o orquestrador solicita confirmação manual no início da sessão
DREAM_SQUAD_ENV=anthropic

# Configuração Ollama (obrigatório apenas para ambiente Ollama)
OLLAMA_API_BASE=https://ollama.com
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_MODEL=kimi-k2.6:cloud
OLLAMA_RESEARCHER_MODEL=kimi-k2.6:cloud
OLLAMA_EMBEDDING_MODEL=qwen3-embedding

# Alerta de custo por execução (USD). Default: 0.50
COST_ALERT_THRESHOLD=0.50

# Modelo Gemini (deixe vazio para usar o padrão do plano)
GEMINI_MODEL=gemini-1.5-flash
