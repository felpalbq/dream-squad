# Copie para .env e preencha os valores reais

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# Ambiente ativo: anthropic | ollama (OBRIGATÓRIO)
# Se não definido, o orquestrador encerra com erro explícito.
DREAM_SQUAD_ENV=anthropic

# Ollama Regional Researcher (pesquisa local via Python SDK)
# Disponível em qualquer ambiente (anthropic ou ollama) se OLLAMA_API_KEY estiver preenchida.
# NÃO é usado para Scoring/Merge — o Scoring/Merge é sempre sub-agente nativo do Claude Code.
OLLAMA_API_BASE=https://ollama.com
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_MODEL=kimi-k2.6:cloud        # modelo para síntese regional
OLLAMA_RESEARCHER_MODEL=kimi-k2.6:cloud  # modelo para web_search/web_fetch

# Tavily
TAVILY_API_KEY=your_tavily_api_key_here

# Apify
APIFY_API_TOKEN=your_apify_api_token_here

# Timeout por agente em segundos (default: 120)
AGENT_TIMEOUT_S=120
